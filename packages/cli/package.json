{
  "name": "skillr",
  "version": "0.2.0",
  "description": "AI Agent Skill Registry CLI - discover, install and manage skills for Claude, Codex, and more",
  "type": "module",
  "bin": {
    "skillr": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "agent",
    "skills",
    "cli",
    "claude",
    "codex",
    "mcp",
    "registry",
    "skill-management"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TokenRollAI/skillr.git"
  },
  "homepage": "https://github.com/TokenRollAI/skillr#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.0.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "tar": "^7.5.11",
    "@skillr/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/tar": "^7.0.87",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
