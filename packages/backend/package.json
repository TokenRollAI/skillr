{
  "name": "@skillr/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "db:migrate": "node --import tsx/esm node_modules/drizzle-kit/bin.cjs migrate",
    "db:generate": "node --import tsx/esm node_modules/drizzle-kit/bin.cjs generate",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@skillr/shared": "workspace:*",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "drizzle-orm": "^0.39.0",
    "postgres": "^3.4.0",
    "jose": "^6.0.0",
    "zod": "^3.24.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "argon2": "^0.41.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.0"
  }
}
