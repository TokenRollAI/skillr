{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/:path*",
        "destination": "http://localhost:3001/api/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/namespaces/[name]",
      "regex": "^/namespaces/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPname": "nxtPname"
      },
      "namedRegex": "^/namespaces/(?<nxtPname>[^/]+?)(?:/)?$"
    },
    {
      "page": "/namespaces/[name]/settings",
      "regex": "^/namespaces/([^/]+?)/settings(?:/)?$",
      "routeKeys": {
        "nxtPname": "nxtPname"
      },
      "namedRegex": "^/namespaces/(?<nxtPname>[^/]+?)/settings(?:/)?$"
    },
    {
      "page": "/skills/[ns]/[name]",
      "regex": "^/skills/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPns": "nxtPns",
        "nxtPname": "nxtPname"
      },
      "namedRegex": "^/skills/(?<nxtPns>[^/]+?)/(?<nxtPname>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/audit",
      "regex": "^/admin/audit(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/audit(?:/)?$"
    },
    {
      "page": "/admin/users",
      "regex": "^/admin/users(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/users(?:/)?$"
    },
    {
      "page": "/device",
      "regex": "^/device(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/device(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/namespaces",
      "regex": "^/namespaces(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/namespaces(?:/)?$"
    },
    {
      "page": "/namespaces/create",
      "regex": "^/namespaces/create(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/namespaces/create(?:/)?$"
    },
    {
      "page": "/register",
      "regex": "^/register(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/register(?:/)?$"
    },
    {
      "page": "/settings",
      "regex": "^/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/settings(?:/)?$"
    },
    {
      "page": "/settings/keys",
      "regex": "^/settings/keys(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/settings/keys(?:/)?$"
    },
    {
      "page": "/skills",
      "regex": "^/skills(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/skills(?:/)?$"
    },
    {
      "page": "/skills/publish",
      "regex": "^/skills/publish(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/skills/publish(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}